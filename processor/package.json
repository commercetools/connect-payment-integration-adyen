{
  "name": "payment-integration-adyen",
  "version": "5.27.1",
  "description": "Payment integration with Adyen",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node_modules/.bin/nodemon -q dist/main.js",
    "lint": "prettier --check \"**/**/*.{ts,js,json}\" && eslint src",
    "lint:fix": "prettier --write \"**/**/*.{ts,js,json}\" && eslint --fix src",
    "build": "rm -rf /dist && tsc",
    "dev": "ts-node src/main.ts",
    "watch": "nodemon --watch \"src/**\" --ext \"ts,json\" --ignore \"src/**/*.spec.ts\" --exec \"ts-node src/main.ts\" --legacy-watch",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --detectOpenHandles --coverage",
    "connector:post-deploy": "node dist/connectors/post-deploy.js",
    "connector:pre-undeploy": "node dist/connectors/pre-undeploy.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@adyen/api-library": "32.0.0",
    "@commercetools-backend/loggers": "27.8.0",
    "@commercetools/connect-payments-sdk": "1.1.0",
    "@fastify/autoload": "6.4.0",
    "@fastify/cors": "11.3.0",
    "@fastify/formbody": "8.0.2",
    "@fastify/http-proxy": "11.6.0",
    "@fastify/request-context": "7.0.0",
    "@fastify/static": "10.1.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@sinclair/typebox": "0.34.49",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "fastify-plugin": "6.0.0"
  },
  "devDependencies": {
    "@commercetools/composable-commerce-test-data": "13.13.1",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "globals": "17.7.0",
    "@jest/globals": "30.4.1",
    "@types/jest": "30.0.0",
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.4",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unused-imports": "4.4.1",
    "jest": "30.4.2",
    "msw": "2.15.0",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.14",
    "prettier": "3.9.5",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "overrides": {
    "lodash": "4.18.1",
    "brace-expansion": "5.0.7",
    "@commercetools/composable-commerce-test-data": {
      "@commercetools-frontend/application-config": {
        "ajv": "8.20.0",
        "dompurify": "3.4.12"
      }
    }
  }
}
